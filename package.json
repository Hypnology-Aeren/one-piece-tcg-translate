{
  "name": "optcg-cevirici",
  "version": "1.4.0",
  "description": "OPTCG Kart Çevirici",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win --publish never",
    "release": "electron-builder --win --publish always"
  },
  "build": {
    "appId": "com.optcg.cevirici",
    "productName": "OPTCG Çevirici",
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "artifactName": "OPTCG-Cevirici-Setup-${version}.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "Hypnology-Aeren",
      "repo": "one-piece-tcg-translate",
      "releaseType": "release"
    },
    "files": [
      "**/*",
      "!optcg-cevirici/**",
      "!optcg-cevirici.zip",
      "!dist/**"
    ]
  },
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "electron-updater": "^6.6.2",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1"
  }
}
